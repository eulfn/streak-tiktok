<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Feener.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Feener.Pages"
    Title="Feener"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate pages:DashboardPage}"
            Route="DashboardPage"
            Shell.TabBarIsVisible="False" />

        <ShellContent
            Title="History"
            ContentTemplate="{DataTemplate pages:HistoryPage}"
            Route="HistoryPage"
            Shell.TabBarIsVisible="False" />

        <ShellContent
            Title="Friends"
            ContentTemplate="{DataTemplate pages:FriendsPage}"
            Route="FriendsPage"
            Shell.TabBarIsVisible="False" />

        <ShellContent
            Title="Profile"
            ContentTemplate="{DataTemplate pages:ProfilePage}"
            Route="ProfilePage"
            Shell.TabBarIsVisible="False" />
    </TabBar>

</Shell>
