<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Feener.LoginPage"
             Title="Login to TikTok"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource OffBlack}}">
    
    <Grid RowDefinitions="Auto, *, Auto">
        
        <!-- Header -->
        <Border Grid.Row="0" 
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                Stroke="Transparent"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,20,20"
                Padding="{StaticResource SpacingLG}">
            <VerticalStackLayout Spacing="{StaticResource SpacingXS}">
                <Label Text="Login to TikTok" 
                       TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                       FontFamily="InterSemiBold"
                       FontSize="20"/>
                <Label Text="Login to your TikTok account. Your session will be saved for background messaging."
                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}"
                       FontSize="13"
                       LineBreakMode="WordWrap"/>
            </VerticalStackLayout>
        </Border>
        
        <!-- WebView -->
        <WebView x:Name="TikTokWebView"
                 Grid.Row="1"
                 Navigated="OnWebViewNavigated"/>
        
        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" 
              Grid.Row="1" 
              IsVisible="True"
              BackgroundColor="{AppThemeBinding Light={StaticResource OverlayLight}, Dark={StaticResource OverlayDark}}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="{StaticResource SpacingMD}">
                <ActivityIndicator IsRunning="True" 
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}"
                                   HeightRequest="48"
                                   WidthRequest="48"/>
                <Label Text="Loading TikTok..."
                       TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray200}}"
                       FontSize="13"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
        
        <!-- Footer Actions -->
        <Border Grid.Row="2" Style="{StaticResource BottomActionBorder}">
            <Grid ColumnDefinitions="*, *" ColumnSpacing="{StaticResource SpacingMD}">
                <Button Text="Back"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HeightRequest="44"
                        Clicked="OnBackClicked"/>
                <Button Grid.Column="1"
                        Text="Refresh"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HeightRequest="44"
                        Clicked="OnRefreshClicked"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
