<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Feener.Pages.DashboardPage"
             Title="Dashboard"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="*, Auto">
        <!-- ═══ Scrollable Content ═══ -->
        <RefreshView Grid.Row="0" x:Name="MainRefreshView" Refreshing="OnRefreshing">
            <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- ─── Header ─── -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,8,0,0">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label x:Name="GreetingLabel"
                               Text="Hi, User"
                               Style="{StaticResource PageTitleLabel}"
                               HorizontalOptions="Start"/>
                        <Label Text="TikTok Streak Automation"
                               FontFamily="InterRegular"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}"
                               HorizontalOptions="Start"/>
                    </VerticalStackLayout>

                    <!-- Profile avatar circle -->
                    <Border Grid.Column="1"
                            WidthRequest="44" HeightRequest="44"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimarySubtle}, Dark={StaticResource Gray800}}"
                            VerticalOptions="Center">
                        <Label Text="🎵"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- ─── Mode Switcher ─── -->
                <Border Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                        Margin="0,8,0,0">
                    <Grid ColumnDefinitions="*,*" HeightRequest="44">
                        <Border x:Name="NormalModeTabBorder"
                                Grid.Column="0"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                StrokeShape="RoundRectangle 22">
                            <Label x:Name="NormalModeTabLabel"
                                   Text="Normal"
                                   TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                                   FontFamily="InterSemiBold"
                                   FontSize="14"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNormalModeTapped" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="BurstModeTabBorder"
                                Grid.Column="1"
                                StrokeThickness="0"
                                BackgroundColor="Transparent"
                                StrokeShape="RoundRectangle 22">
                            <Label x:Name="BurstModeTabLabel"
                                   Text="Burst"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                   FontFamily="InterSemiBold"
                                   FontSize="14"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBurstModeTapped" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </Border>

                <!-- ─── System Status Card (enhanced) ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="System Status" Style="{StaticResource SectionLabel}"/>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="16">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Last Run" Style="{StaticResource DataLabel}"/>
                                <Label x:Name="LastRunLabel" Text="Never" Style="{StaticResource ValueLabel}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Next Run" Style="{StaticResource DataLabel}"/>
                                <Label x:Name="NextRunLabel" Text="Not scheduled" Style="{StaticResource ValueLabel}"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Session status indicator -->
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                            <Border x:Name="SessionDot"
                                    WidthRequest="10" HeightRequest="10"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 5"
                                    BackgroundColor="{StaticResource Gray400}"
                                    VerticalOptions="Center"/>
                            <Label x:Name="SessionStatusLabel"
                                   Grid.Column="1"
                                   Text="Session unknown"
                                   Style="{StaticResource DataLabel}"
                                   VerticalOptions="Center"/>
                            <Label x:Name="SessionActionLabel"
                                   Grid.Column="2"
                                   Text="Check Profile →"
                                   Style="{StaticResource DataLabel}"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   VerticalOptions="Center"
                                   FontFamily="InterSemiBold"/>
                        </Grid>

                        <!-- Success Rate Chart -->
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="16">
                            <GraphicsView x:Name="SuccessChartView"
                                          WidthRequest="80" HeightRequest="80"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label x:Name="SuccessRateLabel"
                                       Text="No data yet"
                                       Style="{StaticResource ValueLabel}"/>
                                <Label x:Name="TotalRunsLabel"
                                       Text=""
                                       Style="{StaticResource DataLabel}"/>
                                <Label x:Name="AvgDurationLabel"
                                       Text=""
                                       Style="{StaticResource DataLabel}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ Normal Mode Container ═══ -->
                <VerticalStackLayout x:Name="NormalModeContainer" IsVisible="True" Spacing="16">

                    <!-- Normal Streak Message -->
                    <Border Style="{StaticResource SectionCard}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Streak Message"
                                   Style="{StaticResource SectionLabel}"/>
                            <Border Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource Gray900}}">
                                <Editor x:Name="MessageEditor"
                                        Placeholder="Enter your streak message..."
                                        HeightRequest="80"
                                        Margin="8"
                                        TextChanged="OnMessageChanged"/>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ═══ Burst Mode Container ═══ -->
                <VerticalStackLayout x:Name="BurstModeContainer" IsVisible="False" Spacing="16">

                    <!-- Burst Status Card -->
                    <Border Style="{StaticResource SectionCard}">
                        <VerticalStackLayout Spacing="14">
                            <Label Text="Burst Status" Style="{StaticResource SectionLabel}"/>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                <Label Text="Sent today" Style="{StaticResource DataLabel}" VerticalOptions="Center"/>
                                <Label x:Name="BurstDailyProgressLabel"
                                       Text="--"
                                       Style="{StaticResource ValueLabel}"
                                       Grid.Column="1"
                                       HorizontalTextAlignment="End"/>

                                <Label Text="Daily limit" Style="{StaticResource DataLabel}" Grid.Row="1" VerticalOptions="Center"/>
                                <Border Grid.Row="1" Grid.Column="1"
                                        Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource Gray900}}"
                                        WidthRequest="80"
                                        HorizontalOptions="End">
                                    <Entry x:Name="BurstDailyLimitEntry"
                                           Text="--"
                                           Keyboard="Numeric"
                                           HorizontalTextAlignment="Center"
                                           Margin="4,2"
                                           Completed="OnBurstLimitChanged"
                                           Unfocused="OnBurstLimitChanged"/>
                                </Border>

                                <Label Text="Estimated time" Style="{StaticResource DataLabel}" Grid.Row="2" VerticalOptions="Center"/>
                                <Label x:Name="BurstTimeEstimateLabel"
                                       Text="--"
                                       Style="{StaticResource ValueLabel}"
                                       Grid.Column="1" Grid.Row="2"
                                       HorizontalTextAlignment="End"/>
                            </Grid>
                            <Label x:Name="BurstPlanLabel"
                                   Text="Calculating plan..."
                                   Style="{StaticResource DataLabel}"
                                   LineBreakMode="WordWrap"
                                   Opacity="0.7"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Burst Target -->
                    <Border Style="{StaticResource SectionCard}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Burst Target" Style="{StaticResource SectionLabel}"/>
                            <Label Text="The single user to burst messages to endlessly." Style="{StaticResource DataLabel}" LineBreakMode="WordWrap"/>
                            <Border Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource Gray900}}">
                                <Entry x:Name="BurstTargetUserEntry"
                                       Placeholder="Username (without @)"
                                       Margin="8,4"
                                       TextChanged="OnBurstSettingsChanged"/>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Burst Messages -->
                    <Border Style="{StaticResource SectionCard}">
                        <VerticalStackLayout Spacing="12">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                                <Label Text="Burst Messages" Style="{StaticResource SectionLabel}"/>
                                <Label Text="App will randomly select one of these." Style="{StaticResource DataLabel}"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout x:Name="BurstMessagesStack" Spacing="8"/>
                            <Button x:Name="AddBurstMessageButton"
                                    Text="+ Add Message"
                                    Style="{StaticResource TextButton}"
                                    HorizontalOptions="Start"
                                    Clicked="OnAddBurstMessageClicked"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ─── Recent Activity ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8">
                            <Label Text="Recent Activity"
                                   Style="{StaticResource SectionLabel}"
                                   VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                    Text="Clear"
                                    Style="{StaticResource TextButton}"
                                    TextColor="{AppThemeBinding Light={StaticResource DeleteColor}, Dark={StaticResource DeleteColor}}"
                                    Clicked="OnClearHistoryClicked"/>
                            <Button Grid.Column="2"
                                    Text="Export Logs"
                                    Style="{StaticResource TextButton}"
                                    Clicked="OnExportLogsClicked"/>
                        </Grid>
                        <VerticalStackLayout x:Name="HistoryContainer" Spacing="8">
                            <Label x:Name="NoHistoryLabel"
                                   Text="No activity yet."
                                   Style="{StaticResource DataLabel}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <Button x:Name="SeeAllHistoryButton"
                                Text="See Full History"
                                Style="{StaticResource TextButton}"
                                HorizontalOptions="Center"
                                IsVisible="False"
                                Clicked="OnSeeAllHistoryClicked"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Footer hint -->
                <Label Text="Pull down to check for updates"
                       FontFamily="InterRegular"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                       HorizontalOptions="Center"
                       Margin="0,24,0,20"/>

            </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ═══ Fixed Bottom Action Bar ═══ -->
        <Border Grid.Row="1" Style="{StaticResource BottomActionBorder}">
            <VerticalStackLayout Spacing="12">

                <!-- Dynamic Permissions Panel -->
                <VerticalStackLayout x:Name="PermissionsPanel" IsVisible="False" Spacing="8">
                    <Label Text="To automate streaks reliably in the background, your device requires the following:"
                           Style="{StaticResource DataLabel}"
                           LineBreakMode="WordWrap"/>
                    <Button x:Name="BtnExactAlarm"
                            Text="Allow Exact Scheduling"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                            TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                            CornerRadius="12" HeightRequest="44"
                            Clicked="OnRequestExactAlarmClicked"/>
                    <Button x:Name="BtnBatteryOpt"
                            Text="Disable Battery Restrictions"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                            TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                            CornerRadius="12" HeightRequest="44"
                            Clicked="OnRequestBatteryOptimizationClicked"/>
                    <Button x:Name="BtnNotification"
                            Text="Allow Status Notifications"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                            TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                            CornerRadius="12" HeightRequest="44"
                            Clicked="OnRequestNotificationClicked"/>
                </VerticalStackLayout>

                <!-- Execution Action -->
                <Grid x:Name="RunButtonsContainer">
                    <Button x:Name="MasterRunButton"
                            Text="Run Normal"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                            FontFamily="InterSemiBold"
                            FontSize="16"
                            CornerRadius="16"
                            HeightRequest="54"
                            Clicked="OnMasterRunClicked"/>
                </Grid>

                <Button x:Name="StopServiceButton"
                        Text="Stop Processing"
                        IsVisible="False"
                        BackgroundColor="{AppThemeBinding Light={StaticResource DeleteColor}, Dark={StaticResource DeleteColor}}"
                        TextColor="White"
                        FontFamily="InterSemiBold"
                        CornerRadius="16"
                        HeightRequest="54"
                        Clicked="OnStopServiceClicked"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
