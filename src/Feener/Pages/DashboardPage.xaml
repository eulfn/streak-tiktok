<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Feener.Views"
             x:Class="Feener.Pages.DashboardPage"
             Title="Dashboard"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource OffBlack}}">

    <Grid>

        <!-- ═══ Scrollable Content ═══ -->
        <RefreshView x:Name="MainRefreshView" Refreshing="OnRefreshing">
            <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- ─── Header ─── -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,8,0,0">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label x:Name="GreetingLabel"
                               Text="Hi, User"
                               Style="{StaticResource PageTitleLabel}"
                               HorizontalOptions="Start"/>
                        <Label Text="TikTok Streak Automation"
                               FontFamily="InterRegular"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}"
                               HorizontalOptions="Start"/>
                    </VerticalStackLayout>

                    <!-- Profile avatar circle -->
                    <Border x:Name="ProfileAvatarBorder"
                            Grid.Column="1"
                            WidthRequest="44" HeightRequest="44"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimarySubtle}, Dark={StaticResource Gray800}}"
                            VerticalOptions="Center">
                        <Image x:Name="ProfileAvatarImage"
                               IsVisible="False"
                               Aspect="AspectFill"
                               WidthRequest="44" HeightRequest="44"/>
                        <!-- Fallback emoji shown when no photo set -->
                    </Border>
                    <Label x:Name="ProfileAvatarEmoji"
                           Grid.Column="1"
                           Text="🎵" FontSize="20"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           InputTransparent="True"/>
                </Grid>

                <!-- ─── Mode Switcher ─── -->
                <Border Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 22"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                        Margin="0,8,0,0">
                    <Grid ColumnDefinitions="*,*" HeightRequest="44">
                        <Border x:Name="NormalModeTabBorder"
                                Grid.Column="0"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                StrokeShape="RoundRectangle 22">
                            <Label x:Name="NormalModeTabLabel"
                                   Text="Normal"
                                   TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                                   FontFamily="InterSemiBold"
                                   FontSize="14"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNormalModeTapped" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="BurstModeTabBorder"
                                Grid.Column="1"
                                StrokeThickness="0"
                                BackgroundColor="Transparent"
                                StrokeShape="RoundRectangle 22">
                            <Label x:Name="BurstModeTabLabel"
                                   Text="Burst"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                   FontFamily="InterSemiBold"
                                   FontSize="14"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBurstModeTapped" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══ Normal Mode Container ═══ -->
                <VerticalStackLayout x:Name="NormalModeContainer" IsVisible="True" Spacing="16">

                    <!-- Live Automation Overview -->
                    <Border Style="{StaticResource SectionCard}">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Live Automation Overview" Style="{StaticResource SectionLabel}"/>
                            
                            <!-- Session indicator -->
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                <Border x:Name="SessionDot"
                                        WidthRequest="8" HeightRequest="8"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 4"
                                        BackgroundColor="{StaticResource Gray400}"
                                        VerticalOptions="Center"/>
                                <Label x:Name="SessionStatusLabel"
                                       Grid.Column="1"
                                       Text="Session unknown"
                                       Style="{StaticResource DataLabel}"
                                       VerticalOptions="Center"/>
                                <Label x:Name="SessionActionLabel"
                                       Grid.Column="2"
                                       Text="Check Profile →"
                                       Style="{StaticResource DataLabel}"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       VerticalOptions="Center"
                                       FontFamily="InterSemiBold"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Sent Today" Style="{StaticResource DataLabel}"/>
                                    <Label x:Name="OverviewSentLabel" Text="0" Style="{StaticResource ValueLabel}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Success" Style="{StaticResource DataLabel}"/>
                                    <Label x:Name="OverviewSuccessLabel" Text="100%" Style="{StaticResource ValueLabel}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Spacing="4">
                                    <Label Text="Remaining" Style="{StaticResource DataLabel}"/>
                                    <Label x:Name="OverviewRemainingLabel" Text="--" Style="{StaticResource ValueLabel}"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"/>

                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Label Text="Next Scheduled Run" Style="{StaticResource DataLabel}"/>
                                    <Label x:Name="NextRunLabel" Text="Not scheduled" FontFamily="InterSemiBold" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center" HorizontalOptions="End">
                                    <Label Text="Last Run" Style="{StaticResource DataLabel}" HorizontalTextAlignment="End"/>
                                    <Label x:Name="LastRunLabel" Text="Never" Style="{StaticResource ValueLabel}" HorizontalTextAlignment="End"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Run Configuration Card -->
                    <Border Style="{StaticResource SectionCard}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Run Configuration" Style="{StaticResource SectionLabel}"/>
                            <Label Text="Message sent to each friend during a streak run" Style="{StaticResource DataLabel}" LineBreakMode="WordWrap"/>
                            <Border Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource Gray900}}">
                                <Editor x:Name="MessageEditor"
                                        Placeholder="Enter your streak message..."
                                        HeightRequest="72"
                                        Margin="12,8"
                                        TextChanged="OnMessageChanged"/>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ═══ Burst Mode Container ═══ -->
                <VerticalStackLayout x:Name="BurstModeContainer" IsVisible="False" Spacing="16">

                    <!-- Burst Progress Card (unique identity) -->
                    <Border Style="{StaticResource SectionCard}">
                        <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="Burst Progress" Style="{StaticResource SectionLabel}"/>
                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        BackgroundColor="{AppThemeBinding Light=#F3EEFF, Dark=#2D2540}"
                                        Padding="8,4">
                                    <Label x:Name="BurstDailyProgressLabel"
                                           Text="0/720"
                                           FontFamily="InterSemiBold" FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource BurstAccent}, Dark={StaticResource BurstAccentDark}}"/>
                                </Border>
                            </Grid>

                            <!-- Linear progress bar -->
                            <GraphicsView x:Name="BurstProgressGraphicsView"
                                          HeightRequest="12"
                                          HorizontalOptions="Fill" />

                            <!-- Stats grid -->
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Remaining" Style="{StaticResource DataLabel}"/>
                                    <Label x:Name="BurstRemainingLabel" Text="--"
                                           Style="{StaticResource ValueLabel}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="Sessions" Style="{StaticResource DataLabel}"/>
                                    <Label x:Name="BurstSessionsLabel" Text="--"
                                           Style="{StaticResource ValueLabel}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Spacing="2">
                                    <Label Text="Est. Time" Style="{StaticResource DataLabel}"/>
                                    <Label x:Name="BurstTimeEstimateLabel" Text="--"
                                           Style="{StaticResource ValueLabel}"/>
                                </VerticalStackLayout>
                            </Grid>

                            <Label x:Name="BurstPlanLabel"
                                   Text="Calculating plan..."
                                   FontFamily="InterRegular"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray500}}"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Burst Configuration -->
                    <Border Style="{StaticResource SectionCard}">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Burst Configuration" Style="{StaticResource SectionLabel}"/>
                            
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Target Username" Style="{StaticResource ControlTitleLabel}"/>
                                <Label Text="The single user to burst messages to endlessly." Style="{StaticResource DataLabel}" LineBreakMode="WordWrap"/>
                                <Border Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource Gray900}}">
                                    <Entry x:Name="BurstTargetUserEntry"
                                           Placeholder="Username (without @)"
                                           Margin="12,4"
                                           TextChanged="OnBurstSettingsChanged"/>
                                </Border>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"/>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="Burst Messages" Style="{StaticResource ControlTitleLabel}"/>
                                <Label Text="App will randomly select one of these." Style="{StaticResource DataLabel}"/>
                                <VerticalStackLayout x:Name="BurstMessagesStack" Spacing="8"/>
                                <Button x:Name="AddBurstMessageButton"
                                        Text="+ Add Message"
                                        Style="{StaticResource TextButton}"
                                        HorizontalOptions="Start"
                                        Clicked="OnAddBurstMessageClicked"/>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"/>

                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                <Label Text="Daily message limit"
                                       Style="{StaticResource DataLabel}" VerticalOptions="Center"/>
                                <Border Grid.Column="1"
                                        Stroke="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource Gray900}}"
                                        WidthRequest="80" HorizontalOptions="End">
                                    <Entry x:Name="BurstDailyLimitEntry"
                                           Text="--"
                                           Keyboard="Numeric"
                                           HorizontalTextAlignment="Center"
                                           Margin="4,2"
                                           Completed="OnBurstLimitChanged"
                                           Unfocused="OnBurstLimitChanged"/>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Footer hint -->
                <Label Text="Pull down to check for updates"
                       FontFamily="InterRegular"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                       HorizontalOptions="Center"
                       Margin="0,8,0,0"/>

                <!-- Nav bar clearance -->
                <BoxView HeightRequest="200" BackgroundColor="Transparent"/>

            </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ═══ Control Dock Overlay ═══ -->
        <VerticalStackLayout VerticalOptions="End" Spacing="16" Margin="0,0,0,24" InputTransparent="False">
            
            <!-- Floating Run Button Container -->
            <Border x:Name="ControlDockBorder"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="20,16"
                    Margin="24,0"
                    BackgroundColor="{AppThemeBinding Light=#E6FFFFFF, Dark=#E61A1B1E}">
                <Border.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#14000000, Dark=#00000000}" Offset="0,4" Radius="16" Opacity="1"/>
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="12">
                    <!-- Dynamic Permissions Panel -->
                    <VerticalStackLayout x:Name="PermissionsPanel" IsVisible="False" Spacing="8">
                        <Label Text="To automate streaks reliably in the background, your device requires the following:"
                               Style="{StaticResource DataLabel}"
                               LineBreakMode="WordWrap"/>
                        <Button x:Name="BtnExactAlarm"
                                Text="Allow Exact Scheduling"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                                TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                CornerRadius="12" HeightRequest="44"
                                Clicked="OnRequestExactAlarmClicked"/>
                        <Button x:Name="BtnBatteryOpt"
                                Text="Disable Battery Restrictions"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                                TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                CornerRadius="12" HeightRequest="44"
                                Clicked="OnRequestBatteryOptimizationClicked"/>
                        <Button x:Name="BtnNotification"
                                Text="Allow Status Notifications"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                                TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                CornerRadius="12" HeightRequest="44"
                                Clicked="OnRequestNotificationClicked"/>
                    </VerticalStackLayout>

                    <!-- Execution Action -->
                    <Grid x:Name="RunButtonsContainer">
                        <Button x:Name="MasterRunButton"
                                Text="Run Normal"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                                FontFamily="InterSemiBold"
                                FontSize="16"
                                CornerRadius="16"
                                HeightRequest="54"
                                Clicked="OnMasterRunClicked"/>
                    </Grid>

                    <Button x:Name="StopServiceButton"
                            Text="Stop Processing"
                            IsVisible="False"
                            BackgroundColor="{AppThemeBinding Light={StaticResource DeleteColor}, Dark={StaticResource DeleteColor}}"
                            TextColor="White"
                            FontFamily="InterSemiBold"
                            CornerRadius="16"
                            HeightRequest="54"
                            Clicked="OnStopServiceClicked"/>
                </VerticalStackLayout>
            </Border>

            <!-- ═══ Floating Nav Bar ═══ -->
            <views:FloatingNavBar CurrentTab="Dashboard"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
